{
  "name": "codex-hud",
  "version": "0.1.0",
  "description": "Real-time HUD for Codex CLI sessions",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "codex-hud": "dist/src/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "commands/",
    ".codex-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"gpt-5.4\"},\"context_window\":{\"context_window_size\":200000,\"current_usage\":{\"input_tokens\":45000}},\"rate_limits\":{\"five_hour\":{\"used_percentage\":25}}}' | node dist/src/index.js"
  },
  "keywords": [
    "codex",
    "codex-cli",
    "statusline",
    "hud"
  ],
  "author": "codex-hud contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macji/codex-hud.git"
  },
  "homepage": "https://github.com/macji/codex-hud#readme",
  "bugs": {
    "url": "https://github.com/macji/codex-hud/issues"
  }
}
